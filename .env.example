"# AI Demo 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ============ DeepSeek API 配置 ============
# 从 https://platform.deepseek.com/ 获取 API Key
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ============ MySQL 数据库配置 ============
# Docker Compose 中使用（容器间通信）
DB_HOST=db
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_mysql_root_password_here

# ============ Redis 配置 ============
# Docker Compose 中使用（容器间通信）
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ============ 本地开发配置 ============
# 本地开发时，可以覆盖上面的配置
# LOCAL_DB_HOST=localhost
# LOCAL_DB_PASSWORD=your_local_mysql_password
# LOCAL_REDIS_HOST=localhost
# LOCAL_REDIS_PASSWORD=your_local_redis_password

# ============ 可选配置 ============
# 激活特定的 Spring Profile
# SPRING_PROFILES_ACTIVE=local,dev

# ============ 安全提示 ============
# 1. 不要将真实的 API Key 和密码提交到版本控制系统
# 2. 生产环境使用更强的密码
# 3. 定期更换 API Key 和密码
# 4. 使用不同的密码用于不同服务"